# Streamlit secrets 예시 파일.
# 실제 운영용 secrets.toml은 .gitignore에 의해 git에 들어가지 않는다.
#
# 사용법:
#   1) 로컬: 본 파일을 secrets.toml로 복사 후 값을 채운다.
#   2) Streamlit Community Cloud: 앱 Settings → Secrets에서 web UI로 동일 키를 등록한다.

# 외부 접근 비밀번호 (단일).
# 심사위원·NGO·자문위원 등 부여 대상에게만 공유.
# 값이 비어 있으면 인증 게이트가 통과되어 로컬 개발용으로 동작한다.
app_access_password = "여기에-강한-비밀번호-입력"

# (선택) 운영 환경 식별자.
# 로그·이벤트 메타에 포함할 환경명 — 예: "beta", "demo-day", "judges".
deployment_label = "demo"

# (선택) Fernet 키 — 배포 환경에서 환경변수 대신 사용 가능.
# 로컬에서는 .env의 APP_SECRET_KEY를 사용한다.
# app_secret_key = "여기에-32바이트-Fernet-키"

# (선택) Anthropic API 키 — 베타 환경에서 실제 OCR 활성화 시.
# anthropic_api_key = "sk-ant-..."
